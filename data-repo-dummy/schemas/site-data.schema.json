{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mljr.eu/schemas/site-data.v1.schema.json",
  "title": "Homepage Site Data",
  "description": "Merged public data artifact consumed by the mljr.eu homepage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "github_projects", "linkedin_data", "strava_data"],
  "properties": {
    "schema_version": {
      "const": "site-data.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "github_projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "linkedin_data": {
      "$ref": "#/$defs/linkedin_data"
    },
    "strava_data": {
      "$ref": "#/$defs/strava_data"
    }
  },
  "$defs": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "asset_or_url": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "url", "stars", "language", "topics", "images"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "$ref": "#/$defs/url"
        },
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "language": {
          "type": "string"
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "images": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset_or_url"
          }
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project_link"
          },
          "default": []
        }
      }
    },
    "project_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "linkedin_data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "name", "headline", "location", "about", "experience", "education", "skills"],
      "properties": {
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "about": {
          "type": "string"
        },
        "experience": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/job"
          }
        },
        "education": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/school"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "photo_url"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "photo_url": {
          "$ref": "#/$defs/asset_or_url"
        },
        "headline": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "company", "type", "period", "duration", "description"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "company": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "school": {
      "type": "object",
      "additionalProperties": false,
      "required": ["school", "degree", "period"],
      "properties": {
        "school": {
          "type": "string",
          "minLength": 1
        },
        "degree": {
          "type": "string",
          "minLength": 1
        },
        "period": {
          "type": "string"
        }
      }
    },
    "strava_data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_stats", "year_to_date_stats", "recent_activities", "best_activities", "personal_records", "disciplines"],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "year": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        },
        "ytd_calories": {
          "type": "number",
          "minimum": 0
        },
        "total_stats": {
          "$ref": "#/$defs/strava_stats"
        },
        "year_to_date_stats": {
          "$ref": "#/$defs/strava_stats"
        },
        "recent_activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/strava_activity"
          }
        },
        "best_activities": {
          "$ref": "#/$defs/strava_best_records"
        },
        "personal_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/strava_record"
          }
        },
        "disciplines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/strava_discipline"
          }
        },
        "monthly_activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/strava_month"
          },
          "default": []
        }
      }
    },
    "strava_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "distance", "moving_time", "elapsed_time", "elevation_gain"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "distance": {
          "type": "number",
          "minimum": 0
        },
        "moving_time": {
          "type": "integer",
          "minimum": 0
        },
        "elapsed_time": {
          "type": "integer",
          "minimum": 0
        },
        "elevation_gain": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "strava_activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "distance", "moving_time", "type"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "distance": {
          "type": "number",
          "minimum": 0
        },
        "moving_time": {
          "type": "integer",
          "minimum": 0
        },
        "elapsed_time": {
          "type": "integer",
          "minimum": 0
        },
        "total_elevation_gain": {
          "type": "number",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "start_date": {
          "type": "string",
          "format": "date-time"
        },
        "start_date_local": {
          "type": "string",
          "format": "date-time"
        },
        "average_pace": {
          "type": "number",
          "minimum": 0
        },
        "average_speed": {
          "type": "number",
          "minimum": 0
        },
        "max_speed": {
          "type": "number",
          "minimum": 0
        },
        "average_heartrate": {
          "type": "number",
          "minimum": 0
        },
        "max_heartrate": {
          "type": "number",
          "minimum": 0
        },
        "calories": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "strava_best_records": {
      "type": "object",
      "additionalProperties": false,
      "required": ["longest_distance", "longest_time", "fastest_pace", "most_elevation"],
      "properties": {
        "longest_distance": {
          "$ref": "#/$defs/strava_activity"
        },
        "longest_time": {
          "$ref": "#/$defs/strava_activity"
        },
        "fastest_pace": {
          "$ref": "#/$defs/strava_activity"
        },
        "most_elevation": {
          "$ref": "#/$defs/strava_activity"
        }
      }
    },
    "strava_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "time", "distance", "date", "activity"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "integer",
          "minimum": 0
        },
        "distance": {
          "type": "number",
          "minimum": 0
        },
        "date": {
          "type": "string"
        },
        "activity": {
          "$ref": "#/$defs/strava_activity"
        }
      }
    },
    "strava_discipline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "count", "total_time", "total_distance", "avg_heartrate"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "total_time": {
          "type": "integer",
          "minimum": 0
        },
        "total_distance": {
          "type": "number",
          "minimum": 0
        },
        "avg_heartrate": {
          "type": "number",
          "minimum": 0
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/strava_activity"
          },
          "default": []
        }
      }
    },
    "strava_month": {
      "type": "object",
      "additionalProperties": false,
      "required": ["month", "count", "distance", "time"],
      "properties": {
        "month": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "distance": {
          "type": "number",
          "minimum": 0
        },
        "time": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
